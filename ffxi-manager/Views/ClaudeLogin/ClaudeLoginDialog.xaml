<Window x:Class="FFXIManager.Views.ClaudeLogin.ClaudeLoginDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:FFXIManager.ViewModels.ClaudeLogin"
        Title="ClaudeLogin — キャラクター管理"
        Height="540" Width="800" MinHeight="400" MinWidth="640"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}">

    <Window.DataContext>
        <vm:ClaudeLoginViewModel/>
    </Window.DataContext>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Windower パス -->
        <GroupBox Grid.Row="0" Header="Windower フォルダ" Margin="0,0,0,8"
                  Foreground="{DynamicResource PrimaryTextBrush}">
            <Grid Margin="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Text="{Binding WindowerPath, UpdateSourceTrigger=PropertyChanged}"
                         Grid.Column="0" Margin="0,0,4,0"/>
                <Button Content="参照..." Grid.Column="1"
                        Command="{Binding BrowseWindowerCommand}"
                        Style="{StaticResource SecondaryButton}" MinWidth="60"/>
            </Grid>
        </GroupBox>

        <!-- キャラクターリスト + 詳細 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左: リスト -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <ListBox Grid.Row="0"
                         ItemsSource="{Binding Characters}"
                         SelectedItem="{Binding Selected}"
                         DisplayMemberPath="Name"
                         Background="{DynamicResource SurfaceBrush}"
                         Foreground="{DynamicResource PrimaryTextBrush}"
                         BorderBrush="{DynamicResource BorderBrush}"/>

                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,4,0,0">
                    <Button Content="追加" Command="{Binding AddCommand}"
                            Style="{StaticResource PrimaryButton}" MinWidth="60" Margin="0,0,4,0"/>
                    <Button Content="削除" Command="{Binding DeleteCommand}"
                            Style="{StaticResource SecondaryButton}" MinWidth="60"/>
                </StackPanel>
            </Grid>

            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                          Background="{DynamicResource DividerBrush}"/>

            <!-- 右: 詳細編集 -->
            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                <StackPanel IsEnabled="{Binding HasSelection}" Margin="8,0,0,0">

                    <Label Content="キャラ名"/>
                    <TextBox Text="{Binding Selected.Name, UpdateSourceTrigger=PropertyChanged}"/>

                    <Label Content="パスワード" Margin="4,8,4,0"/>
                    <TextBox Text="{Binding Selected.Password, UpdateSourceTrigger=PropertyChanged}"/>

                    <Label Content="TOTP シークレット（使わない場合は空）" Margin="4,8,4,0"/>
                    <TextBox Text="{Binding Selected.TotpSecret, UpdateSourceTrigger=PropertyChanged}"/>

                    <Label Content="スロット（1〜4）" Margin="4,8,4,0"/>
                    <ComboBox SelectedValue="{Binding Selected.Slot}" Margin="4">
                        <ComboBoxItem Content="1" Tag="1"/>
                        <ComboBoxItem Content="2" Tag="2"/>
                        <ComboBoxItem Content="3" Tag="3"/>
                        <ComboBoxItem Content="4" Tag="4"/>
                    </ComboBox>

                    <Label Content="キャラセット（chars bin）" Margin="4,8,4,0"/>
                    <ComboBox ItemsSource="{Binding DataContext.AvailableBins,
                                RelativeSource={RelativeSource AncestorType=Window}}"
                              Text="{Binding Selected.CharsBin, UpdateSourceTrigger=PropertyChanged}"
                              IsEditable="True" Margin="4"/>

                    <Label Content="Windower 引数（任意）" Margin="4,8,4,0"/>
                    <TextBox Text="{Binding Selected.Args, UpdateSourceTrigger=PropertyChanged}"/>

                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- セットアップ: bin キャプチャ -->
        <GroupBox Grid.Row="2" Header="セットアップ — chars bin の取り込み" Margin="0,8,0,0"
                  Foreground="{DynamicResource PrimaryTextBrush}">
            <StackPanel Margin="4" Orientation="Horizontal">
                <Button Content="現在の login_w.bin を新しい chars bin として保存"
                        Command="{Binding CaptureCurrentBinCommand}"
                        Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"/>
                <TextBlock Text="※ POL を起動→終了後に実行してください"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           FontSize="11"/>
            </StackPanel>
        </GroupBox>

        <!-- 下部: ステータス + 保存 -->
        <Grid Grid.Row="3" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="{Binding StatusMessage}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource SecondaryTextBrush}"/>

            <Button Grid.Column="1" Content="再読み込み"
                    Command="{Binding LoadCommand}"
                    Style="{StaticResource SecondaryButton}"
                    MinWidth="80" Margin="0,0,8,0"/>

            <Button Grid.Column="2" Content="保存"
                    Command="{Binding SaveCommand}"
                    Style="{StaticResource PrimaryButton}"
                    MinWidth="80"/>
        </Grid>
    </Grid>
</Window>
